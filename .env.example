# === КОНФИГУРАЦИЯ PYNEX SEARCH ENGINE ===
# Скопируйте этот файл в .env и заполните переменные
# cp .env.example .env

# === FASTAPI ===
# Фронтенд URL (для CORS)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000,http://127.0.0.1:8000

# Порог доверия для классификации (0.0 - 1.0)
# Если уверенность модели ниже этого значения, запрос будет помечен как "Uncategorized"
CONFIDENCE_THRESHOLD=0.2

# === GOOGLE CUSTOM SEARCH ENGINE ===
# Получить CX ID: https://programmablesearchengine.google.com/cse/create/new
# Скопируйте значение "Search engine ID" (cx)
GOOGLE_CSE_CX=7710f95b27df946a1

# === ЛОГИРОВАНИЕ ===
# Уровень логирования: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# === ML МОДЕЛЬ ===
# Путь к сохраненной модели
MODEL_PATH=query_model.pkl

# Путь к файлу логов
LOG_FILE=queries_log.jsonl

# === SECURITY ===
# Для production используйте HTTPS и правильно настройте CORS
API_URL=http://localhost:8000
ENVIRONMENT=development

# development | staging | production
# На production выставить в production и включить HTTPS
